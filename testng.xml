<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="OrangeHRM Suite">

    <listeners>
        <listener class-name="base.Listeners"/>
    </listeners>

    <test name="Chrome Tests">

        <parameter name="browser" value="chrome"/>
        <parameter name="headless" value="false"/>

        <classes>

            <class name="tests.LoginTest"/>
            <class name="tests.DashboardTest"/>
            <class name="tests.AdminTest"/>
            <class name="tests.PIMTest"/>
            <class name="tests.LeaveTest"/>
            <class name="tests.TimeTest"/>
            <class name="tests.RecruitmentTest"/>
            <class name="tests.MyInfoTest"/>
            <class name="tests.PerformanceTest"/>
            <class name="tests.DirectoryTest"/>
            <class name="tests.ClaimTest"/>
            <class name="tests.BuzzTest"/>
            <class name="tests.EndToEndTest"/>

        </classes>

    </test>

</suite>